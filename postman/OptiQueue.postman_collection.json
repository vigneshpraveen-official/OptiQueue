{
  "info": {
    "name": "OptiQueue",
    "description": "Full API walkthrough with role-based flows. Set {{baseUrl}} (defaults to http://localhost:8080). Run 'Login admin' / 'Login staff' / 'Register customer' first — tokens are stored into collection variables automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "adminToken", "value": "" },
    { "key": "staffToken", "value": "" },
    { "key": "customerToken", "value": "" },
    { "key": "productId", "value": "1" },
    { "key": "orderId", "value": "1" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200', () => pm.response.to.have.status(200));",
                  "pm.collectionVariables.set('adminToken', pm.response.json().token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": { "mode": "raw", "raw": "{\"username\":\"admin\",\"password\":\"admin12345\"}" }
          }
        },
        {
          "name": "Login staff",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200', () => pm.response.to.have.status(200));",
                  "pm.collectionVariables.set('staffToken', pm.response.json().token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": { "mode": "raw", "raw": "{\"username\":\"staff\",\"password\":\"staff12345\"}" }
          }
        },
        {
          "name": "Register customer",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.collectionVariables.set('customerName', 'buyer' + Date.now());"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('201', () => pm.response.to.have.status(201));",
                  "pm.test('role is CUSTOMER', () => pm.expect(pm.response.json().role).to.eql('CUSTOMER'));",
                  "pm.collectionVariables.set('customerToken', pm.response.json().token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": { "mode": "raw", "raw": "{\"username\":\"{{customerName}}\",\"password\":\"password123\"}" }
          }
        },
        {
          "name": "Register as ADMIN — rejected 403",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('403 ROLE_NOT_ALLOWED', () => {",
                  "  pm.response.to.have.status(403);",
                  "  pm.expect(pm.response.json().error).to.eql('ROLE_NOT_ALLOWED');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": { "mode": "raw", "raw": "{\"username\":\"evil{{$timestamp}}\",\"password\":\"password123\",\"role\":\"ADMIN\"}" }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List products (any authenticated, cached)",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('200', () => pm.response.to.have.status(200));"] }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/api/products?page=0&size=20"
          }
        },
        {
          "name": "Create product (ADMIN)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('201', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('productId', pm.response.json().id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/products",
            "body": { "mode": "raw", "raw": "{\"sku\":\"PM-{{$timestamp}}\",\"name\":\"Postman Product\",\"price\":149.99,\"stockQuantity\":30}" }
          }
        },
        {
          "name": "Create product as CUSTOMER — rejected 403",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('403', () => pm.response.to.have.status(403));"] }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/products",
            "body": { "mode": "raw", "raw": "{\"sku\":\"HACK-1\",\"name\":\"Nope\",\"price\":1.00,\"stockQuantity\":1}" }
          }
        },
        {
          "name": "Get product by id",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('200', () => pm.response.to.have.status(200));"] }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/api/products/{{productId}}"
          }
        },
        {
          "name": "Update product (ADMIN or STAFF)",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('200', () => pm.response.to.have.status(200));"] }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{staffToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/products/{{productId}}",
            "body": { "mode": "raw", "raw": "{\"name\":\"Postman Product (updated)\",\"price\":159.99}" }
          }
        },
        {
          "name": "Restock (ADMIN or STAFF)",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('200', () => pm.response.to.have.status(200));"] }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{staffToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/products/{{productId}}/restock",
            "body": { "mode": "raw", "raw": "{\"quantity\":10}" }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Place order (CUSTOMER — concurrency-critical)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('201 CONFIRMED', () => {",
                  "  pm.response.to.have.status(201);",
                  "  pm.expect(pm.response.json().status).to.eql('CONFIRMED');",
                  "});",
                  "pm.collectionVariables.set('orderId', pm.response.json().orderId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/orders",
            "body": { "mode": "raw", "raw": "{\"items\":[{\"productId\":{{productId}},\"quantity\":2}]}" }
          }
        },
        {
          "name": "Order too large — 409 INSUFFICIENT_STOCK",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('409 INSUFFICIENT_STOCK', () => {",
                  "  pm.response.to.have.status(409);",
                  "  pm.expect(pm.response.json().error).to.eql('INSUFFICIENT_STOCK');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/orders",
            "body": { "mode": "raw", "raw": "{\"items\":[{\"productId\":{{productId}},\"quantity\":99999}]}" }
          }
        },
        {
          "name": "My orders (CUSTOMER)",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('200', () => pm.response.to.have.status(200));"] }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/api/orders/mine"
          }
        },
        {
          "name": "Order detail (owner)",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('200', () => pm.response.to.have.status(200));"] }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/api/orders/{{orderId}}"
          }
        },
        {
          "name": "List all orders (ADMIN/STAFF)",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('200', () => pm.response.to.have.status(200));"] }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{staffToken}}" }],
            "url": "{{baseUrl}}/api/orders"
          }
        },
        {
          "name": "List all orders as CUSTOMER — rejected 403",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('403', () => pm.response.to.have.status(403));"] }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/api/orders"
          }
        },
        {
          "name": "Ship order (ADMIN/STAFF)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 SHIPPED', () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().status).to.eql('SHIPPED');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{staffToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/orders/{{orderId}}/status",
            "body": { "mode": "raw", "raw": "{\"status\":\"SHIPPED\"}" }
          }
        },
        {
          "name": "Invalid transition — 422",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('422 INVALID_TRANSITION', () => {",
                  "  pm.response.to.have.status(422);",
                  "  pm.expect(pm.response.json().error).to.eql('INVALID_TRANSITION');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{staffToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/orders/{{orderId}}/status",
            "body": { "mode": "raw", "raw": "{\"status\":\"CONFIRMED\"}" }
          }
        }
      ]
    },
    {
      "name": "No token — 401",
      "event": [
        {
          "listen": "test",
          "script": { "exec": ["pm.test('401', () => pm.response.to.have.status(401));"] }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/products"
      }
    }
  ]
}
